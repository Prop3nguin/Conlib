# Copy this file to .env (setup.sh does this automatically on first run).
# .env is git-ignored — never commit real secrets.

# Flask secret key — used for session signing. Generate a real one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-value

# Database connection string.
# Default (SQLite, local file): leave unset, or set explicitly:
# DATABASE_URL=sqlite:///instance/conlang.db
#
# To switch to Postgres later, just change this line:
# DATABASE_URL=postgresql://user:password@localhost:5432/conlang

# Server binding
# 0.0.0.0 = reachable by anyone on your LAN
# 127.0.0.1 = this machine only
HOST=0.0.0.0
PORT=5000
DEBUG=true